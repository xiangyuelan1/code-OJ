generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(uuid())
  username        String       @unique
  email           String       @unique
  password        String
  role            String       @default("STUDENT")
  avatar          String?
  points          Int          @default(0)
  level           Int          @default(1)
  rank            Int          @default(0)
  isOnline        Boolean      @default(false)
  isActive        Boolean      @default(true)
  trialStartsAt   DateTime?
  accessExpiresAt DateTime?
  accessType      String       @default("TRIAL")
  paymentId       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  submissions     Submission[]
  sessions        Session[]
  achievements    UserAchievement[]
  matchParticipations MatchParticipant[]
  examAttempts    ExamAttempt[]
  pointLogs       PointLog[]
  classes         Class[]           @relation("UserClasses")
  classMemberships ClassMember[]
  payments        Payment[]
  joinRequests    ClassJoinRequest[]
  createdHomework Homework[]        @relation("UserCreatedHomework")
  homeworkSubmissions HomeworkSubmission[]
  aiUsageLogs    AIUsageLog[]
  createdExams   Exam[]             @relation("UserExams")
  learnerProfile   LearnerProfile?
  discussions      Discussion[]
  replies          Reply[]
  discussionVotes  DiscussionVote[]
  dailyChallenges  UserDailyChallenge[]
  planetProgresses UserPlanetProgress[]
  learningPaths    LearningPath[]
  learningAchievements LearningAchievement[]
  storyProgresses  UserStoryProgress[]
  planetBuildings  PlanetBuilding[]
  starPathFriends  StarPathFriend[]  @relation("StarPathFriends")
  starPathFriendOf StarPathFriend[]  @relation("StarPathFriendOf")
  teamMemberships  TeamMember[]
  eventParticipations UserEventParticipation[]
  skillSnapshots   UserSkillSnapshot[]
  dailyChests      UserDailyChest[]
  spacePet         UserSpacePet?
  planetCustoms    UserPlanetCustomization[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  socketId     String
  connectedAt  DateTime @default(now())
  lastActivity DateTime @default(now())
  ip           String?
}

model KnowledgeTree {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  level       Int      @default(1)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  parent      KnowledgeTree?  @relation("KnowledgeTreeRelation", fields: [parentId], references: [id])
  children    KnowledgeTree[] @relation("KnowledgeTreeRelation")
  problems    Problem[]
  starRegion  StarRegion?
}

model Problem {
  id                    String       @id @default(uuid())
  title                 String
  description           String
  type                  String
  difficulty            String       @default("MEDIUM")
  tags                  String       @default("[]")
  testCases             String       @default("[]")
  timeLimit             Int          @default(2000)
  memoryLimit           Int          @default(256)
  choices               String?
  fillBlanks            String?
  correctAnswer         String?
  solution              String?
  knowledgeTreeId       String?
  sourceFile            String?
  knowledgeTree         KnowledgeTree? @relation(fields: [knowledgeTreeId], references: [id])
  aiGeneratedTestCases  Boolean      @default(false)
  aiGeneratedSolution   Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  solutions             Solution[]
  submissions           Submission[]
  examQuestions         ExamQuestion[]
  matchProblems         MatchProblem[]
  discussions           Discussion[]
  dailyChallenges       DailyChallenge[]
}

model Solution {
  id         String   @id @default(uuid())
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  title      String
  content    String
  code       String?
  complexity String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id])
  type        String
  code        String?
  answer      String?
  result      String?
  status      String   @default("PENDING")
  score       Int?
  pointsEarned Int?   @default(0)
  createdAt   DateTime @default(now())
  matchParticipantId String?
  matchParticipant MatchParticipant? @relation(fields: [matchParticipantId], references: [id])
}

model Match {
  id                   String   @id @default(uuid())
  type                 String
  status               String   @default("WAITING")
  currentProblemIndex  Int      @default(0)
  startTime            DateTime @default(now())
  endTime              DateTime?
  winnerId             String?
  rewards              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  participants         MatchParticipant[]
  problems             MatchProblem[]
}

model MatchProblem {
  id        String  @id @default(uuid())
  matchId   String
  match     Match   @relation(fields: [matchId], references: [id])
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id])
  order     Int     @default(0)
}

model MatchParticipant {
  id               String   @id @default(uuid())
  matchId          String
  match            Match    @relation(fields: [matchId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  score            Int      @default(0)
  correctCount     Int      @default(0)
  totalTime        Int      @default(0)
  isWinner         Boolean  @default(false)
  lastSettlementAt DateTime?
  submissions      Submission[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Exam {
  id                String   @id @default(uuid())
  title             String
  description       String?
  type              String
  duration          Int      @default(60)
  startTime         DateTime?
  endTime           DateTime?
  enableProctoring  Boolean  @default(false)
  maxAttempts       Int      @default(1)
  createdBy         String
  creator           User     @relation("UserExams", fields: [createdBy], references: [id])
  classId           String?
  isActive         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  questions         ExamQuestion[]
  attempts         ExamAttempt[]
  class            Class?   @relation(fields: [classId], references: [id])
}

model ExamQuestion {
  id        String  @id @default(uuid())
  examId    String
  exam      Exam    @relation(fields: [examId], references: [id])
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id])
  order     Int     @default(0)
  points    Int     @default(10)
}

model ExamAttempt {
  id              String   @id @default(uuid())
  examId          String
  exam            Exam     @relation(fields: [examId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  startTime       DateTime @default(now())
  endTime         DateTime?
  score           Int?
  status          String   @default("IN_PROGRESS")
  answers         String?
  proctoringLogs  String?
  violations      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Achievement {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  icon        String?
  criteria    String
  points      Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt     DateTime    @default(now())
  progress      String      @default("{}")
  
  @@unique([userId, achievementId])
}

model LevelConfig {
  id         String   @id @default(uuid())
  level      Int      @unique
  name       String
  minPoints  Int
  maxPoints  Int?
  privileges String   @default("[]")
  icon       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PointLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  delta     Int
  reason    String
  details   String?
  createdAt DateTime @default(now())
}

model AIConfig {
  id        String   @id @default(uuid())
  enabled   Boolean  @default(false)
  provider  String   @default("openai")
  apiKey    String?
  baseUrl   String?
  model     String   @default("gpt-3.5-turbo")
  updatedAt DateTime @updatedAt
}

model AIFeatureConfig {
  id             String   @id @default(uuid())
  featureKey     String   @unique
  featureName    String
  description    String   @default("")
  enabled        Boolean  @default(true)
  promptTemplate String   @default("")
  maxTokens      Int      @default(4000)
  temperature    Float    @default(0.7)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Class {
  id            String   @id @default(uuid())
  name          String
  description   String?
  grade         String?
  classCode     String   @default("")
  aiBillingMode String   @default("STUDENT_PAYS")
  createdBy     String
  creator       User     @relation("UserClasses", fields: [createdBy], references: [id])
  members       ClassMember[]
  joinRequests  ClassJoinRequest[]
  homeworks     Homework[]
  exams         Exam[]
  initiatorBattles  ClassBattle[] @relation("InitiatorBattles")
  challengerBattles ClassBattle[] @relation("ChallengerBattles")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("classes")
}

model ClassMember {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("STUDENT")
  joinedAt  DateTime @default(now())
  
  @@unique([classId, userId])
  @@map("class_members")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Payment {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  amount       Float
  method       String
  status       String    @default("PENDING")
  proof        String?
  qrCodeUrl    String?
  reviewedBy   String?
  reviewedAt   DateTime?
  planId       String?
  promotionId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Order {
  id           String     @id @default(uuid())
  userId       String
  planId       String
  plan         PricingPlan @relation(fields: [planId], references: [id])
  amount       Float
  originalAmount Float?
  promotionId  String?
  status       String     @default("PENDING")
  paymentMethod String?
  paidAt       DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ClassJoinRequest {
  id         String   @id @default(uuid())
  classId    String
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  status     String   @default("PENDING")
  message    String?
  reviewedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([classId, userId])
}

model Homework {
  id          String   @id @default(uuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  description String?
  problemIds  String   @default("[]")
  dueDate     DateTime?
  createdBy   String
  creator     User     @relation("UserCreatedHomework", fields: [createdBy], references: [id])
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submissions HomeworkSubmission[]
}

model HomeworkSubmission {
  id          String    @id @default(uuid())
  homeworkId  String
  homework    Homework  @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  problemId   String
  status      String    @default("PENDING")
  score       Int?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([homeworkId, userId, problemId])
}

model ClassBattle {
  id                String   @id @default(uuid())
  initiatorClassId  String
  initiatorClass    Class    @relation("InitiatorBattles", fields: [initiatorClassId], references: [id])
  challengerClassId String
  challengerClass   Class    @relation("ChallengerBattles", fields: [challengerClassId], references: [id])
  status            String   @default("PENDING")
  problemIds        String   @default("[]")
  initiatorScore    Int      @default(0)
  challengerScore   Int      @default(0)
  winnerId          String?
  startTime         DateTime?
  endTime           DateTime?
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AIUsageLog {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  feature           String
  model             String?
  promptTokens      Int      @default(0)
  completionTokens  Int      @default(0)
  totalTokens       Int      @default(0)
  cost              Float    @default(0)
  createdAt         DateTime @default(now())
}

model Promotion {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  description   String?
  type          String    @default("TRIAL_EXTEND")
  value         Int       @default(0)
  maxUses       Int       @default(0)
  currentUses   Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  usages        PromotionUsage[]
}

model PromotionUsage {
  id           String    @id @default(uuid())
  promotionId  String
  promotion    Promotion @relation(fields: [promotionId], references: [id])
  userId       String
  createdAt    DateTime  @default(now())

  @@unique([promotionId, userId])
}

model PricingPlan {
  id          String    @id @default(uuid())
  name        String
  price       Float
  duration    Int       @default(30)
  unit        String    @default("DAY")
  features    String    @default("[]")
  isPopular   Boolean   @default(false)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
}

model LearnerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  knowledgeMap    String   @default("{}")
  abilityRadar    String   @default("{}")
  learningStyle   String   @default("balanced")
  weakPoints      String   @default("[]")
  currentPath     String   @default("{}")
  dailyGoal       Int      @default(3)
  streakDays      Int      @default(0)
  lastActiveAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Discussion {
  id          String    @id @default(uuid())
  problemId   String?
  problem     Problem?  @relation(fields: [problemId], references: [id])
  title       String
  content     String
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  type        String    @default("QUESTION")
  tags        String    @default("[]")
  upvotes     Int       @default(0)
  replyCount  Int       @default(0)
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  replies     Reply[]
  votes       DiscussionVote[]
}

model Reply {
  id           String     @id @default(uuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  content      String
  authorId     String
  author       User       @relation(fields: [authorId], references: [id])
  upvotes      Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model DiscussionVote {
  id           String     @id @default(uuid())
  discussionId String?
  discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  replyId      String?
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  isUpvote     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@unique([userId, discussionId])
}

model DailyChallenge {
  id          String   @id @default(uuid())
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id])
  date        String   @unique
  difficulty  String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  userChallenges UserDailyChallenge[]
}

model UserDailyChallenge {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  dailyChallengeId String
  dailyChallenge DailyChallenge @relation(fields: [dailyChallengeId], references: [id])
  solved        Boolean  @default(false)
  timeTaken     Int?
  submittedAt   DateTime?
  createdAt     DateTime @default(now())

  @@unique([userId, dailyChallengeId])
}

model StarRegion {
  id              String       @id @default(uuid())
  name            String
  description     String       @default("")
  icon            String       @default("⭐")
  color           String       @default("#4FC3F7")
  order           Int          @default(0)
  knowledgeTreeId String?          @unique
  knowledgeTree   KnowledgeTree? @relation(fields: [knowledgeTreeId], references: [id])
  planets         StarPlanet[]
  storyArc        StoryArc?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model StarPlanet {
  id          String              @id @default(uuid())
  regionId    String
  region      StarRegion          @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name        String
  description String              @default("")
  difficulty  String              @default("MEDIUM")
  tags        String              @default("[]")
  order       Int                 @default(0)
  posX        Float               @default(0)
  posY        Float               @default(0)
  problemIds  String              @default("[]")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  progress    UserPlanetProgress[]
  chapters    StoryChapter[]
  buildings      PlanetBuilding[]
  customizations UserPlanetCustomization[]
}

model UserPlanetProgress {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  planetId    String
  planet      StarPlanet @relation(fields: [planetId], references: [id])
  status      String     @default("UNEXPLORED")
  score       Int        @default(0)
  attempts    Int        @default(0)
  lastVisitAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, planetId])
}

model InterviewTemplate {
  id              String   @id @default(uuid())
  role            String
  difficulty      String
  question        String
  expectedTopics  String   @default("[]")
  hints           String   @default("[]")
  correctAnswer   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BugScenario {
  id              String   @id @default(uuid())
  topic           String
  difficulty      String
  buggyCode       String
  correctCode     String
  hints           String   @default("[]")
  bugExplanations String   @default("[]")
  language        String   @default("python")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemFeature {
  id          String   @id @default(uuid())
  featureKey  String   @unique
  featureName String
  description String   @default("")
  category    String   @default("general")
  enabled     Boolean  @default(true)
  visible     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LearningPath {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  title        String
  description  String   @default("")
  difficulty   String   @default("MEDIUM")
  status       String   @default("ACTIVE")
  totalSteps   Int      @default(0)
  completedSteps Int    @default(0)
  regionIds    String   @default("[]")
  planetIds    String   @default("[]")
  problemIds   String   @default("[]")
  generatedBy  String   @default("AI")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  steps        LearningPathStep[]
}

model LearningPathStep {
  id         String       @id @default(uuid())
  pathId     String
  path       LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  order      Int
  type       String
  referenceId String
  title      String
  description String     @default("")
  completed  Boolean     @default(false)
  completedAt DateTime?
}

model LearningAchievement {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  title       String
  description String   @default("")
  icon        String   @default("🏆")
  earnedAt    DateTime @default(now())

  @@unique([userId, type])
}

model AIProviderConfig {
  id          String   @id @default(uuid())
  name        String
  provider    String   @default("openai")
  apiKey      String?
  baseUrl     String?
  model       String   @default("gpt-3.5-turbo")
  isDefault   Boolean  @default(false)
  maxTokens   Int      @default(4000)
  temperature Float    @default(0.7)
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StoryArc {
  id          String   @id @default(uuid())
  regionId    String   @unique
  region      StarRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)
  title       String
  prologue    String   @default("")
  epilogue    String   @default("")
  theme       String   @default("exploration")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chapters    StoryChapter[]
}

model StoryChapter {
  id              String   @id @default(uuid())
  arcId           String
  arc             StoryArc @relation(fields: [arcId], references: [id], onDelete: Cascade)
  planetId        String?
  planet          StarPlanet? @relation(fields: [planetId], references: [id])
  order           Int      @default(0)
  title           String
  narrative       String   @default("")
  completionText  String   @default("")
  isBoss          Boolean  @default(false)
  bossProblemIds  String   @default("[]")
  rewardPoints    Int      @default(0)
  rewardBuildingType String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userProgress    UserStoryProgress[]

  @@unique([arcId, order])
}

model UserStoryProgress {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  chapterId    String
  chapter      StoryChapter @relation(fields: [chapterId], references: [id])
  completed    Boolean  @default(false)
  completedAt  DateTime?

  @@unique([userId, chapterId])
}

model SeasonEvent {
  id              String   @id @default(uuid())
  name            String
  description     String   @default("")
  theme           String   @default("default")
  eventType       String   @default("SEASON")
  bonusMultiplier Float    @default(1.0)
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  specialRegionId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  participations  UserEventParticipation[]
}

model UserEventParticipation {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  eventId   String
  event     SeasonEvent @relation(fields: [eventId], references: [id])
  score     Int        @default(0)
  completed Boolean    @default(false)
  joinedAt  DateTime   @default(now())

  @@unique([userId, eventId])
}

model PlanetBuilding {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  planetId     String
  planet       StarPlanet @relation(fields: [planetId], references: [id])
  buildingType String
  level        Int      @default(1)
  builtAt      DateTime @default(now())
  upgradedAt   DateTime?

  @@unique([userId, planetId, buildingType])
}

model StarPathFriend {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("StarPathFriends", fields: [userId], references: [id])
  friendId   String
  friend     User     @relation("StarPathFriendOf", fields: [friendId], references: [id])
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, friendId])
}

model TeamChallenge {
  id           String   @id @default(uuid())
  title        String
  description  String   @default("")
  regionId     String?
  planetIds    String   @default("[]")
  maxTeamSize  Int      @default(3)
  startTime    DateTime
  endTime      DateTime
  status       String   @default("UPCOMING")
  rewardPoints Int      @default(0)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  teams        ChallengeTeam[]
}

model ChallengeTeam {
  id          String   @id @default(uuid())
  challengeId String
  challenge   TeamChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  name        String
  score       Int      @default(0)
  rank        Int?
  members     TeamMember[]
  createdAt   DateTime @default(now())
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  team     ChallengeTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
}

model UserSkillSnapshot {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  snapshotDate         String
  totalPlanetsMastered Int      @default(0)
  totalScore           Int      @default(0)
  skillRadar           String   @default("{}")
  regionProgress       String   @default("{}")
  createdAt            DateTime @default(now())

  @@unique([userId, snapshotDate])
}

model UserDailyChest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  chestDate   String
  pointsWon   Int      @default(0)
  openedAt    DateTime @default(now())

  @@unique([userId, chestDate])
}

model UserSpacePet {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  petType     String   @default("star_cat")
  petName     String   @default("星喵")
  mood        Int      @default(80)
  level       Int      @default(1)
  exp         Int      @default(0)
  accessories String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserPlanetCustomization {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  planetId    String
  planet      StarPlanet @relation(fields: [planetId], references: [id])
  customName  String?
  customColor String?
  emoji       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, planetId])
}
